        "    docs = retriever.invoke(query)[:3]\n",
        "\n",
        "    context = \"\\n\\n\".join([doc.page_content for doc in docs])\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "You are a helpful assistant. Answer ONLY using the context.\n",
        "\n",
        "Context:\n",
        "{context}\n",
        "\n",
        "Question:\n",
        "{query}\n",
        "\n",
        "Answer:\n",
        "\"\"\"\n",
        "\n",
        "    result = pipe(prompt, max_new_tokens=200)[0]['generated_text']\n",
        "\n",
        "    print(\"\\n🧠 Answer:\\n\")\n",
        "    print(result)\n",
        "\n",
        "    print(\"\\n📚 Sources:\\n\")\n",
        "    for doc in docs:\n",
        "        print(\"-\", doc.metadata)"
